{
    "name": "pp-node",
    "type": "module",
    "dependencies": {
        "@chainsafe/libp2p-noise": "^17.0.0",
        "@chainsafe/libp2p-yamux": "^8.0.1",
        "@fastify/cors": "^11.0.1",
        "@fastify/multipart": "^9.0.3",
        "@fastify/schedule": "^6.0.0",
        "@fastify/static": "^8.2.0",
        "@libp2p/http": "^2.0.1",
        "@libp2p/http-server": "^2.0.1",
        "@libp2p/tcp": "^11.0.10",
        "@noble/post-quantum": "^0.4.1",
        "ajv": "^8.17.1",
        "commander": "^13.1.0",
        "fastify": "^5.3.2",
        "libp2p": "^3.1.3",
        "pp-js-lib": "github:people-post/pp-js-lib#ff37f682a7a5a470a27a61d80b64c4be2aaa6b1e",
        "sharp": "^0.34.4",
        "toad-scheduler": "^3.1.0"
    },
    "devDependencies": {
        "@types/node": "^25.0.3",
        "esbuild": "^0.25.9",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "scripts": {
        "build": "tsc",
        "bundle": "esbuild src/index.ts --bundle --platform=node --outfile=bundle.js --format=esm --external:pp-js-lib --external:node:* --external:@fastify/* --external:sharp --external:commander --external:fastify --external:ajv --external:toad-scheduler --external:@noble/post-quantum --log-level=warning",
        "check": "tsc --noEmit",
        "test": "node --import tsx --test src/**/*.test.ts",
        "test:watch": "node --import tsx --test --watch src/**/*.test.ts"
    }
}
